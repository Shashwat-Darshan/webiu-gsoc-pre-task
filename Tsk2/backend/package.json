{
  "name": "github-repo-intelligence-analyzer",
  "version": "1.0.0",
  "description": "Task 2 backend for GitHub repository intelligence analysis",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start:lambda": "node -e \"require('./dist/serverless/lambda.js'); console.log('Lambda handler is ready.');\""
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@octokit/plugin-throttling": "^11.0.3",
    "@octokit/rest": "^21.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "p-limit": "^5.0.0",
    "serverless-http": "^3.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.6",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  }
}
